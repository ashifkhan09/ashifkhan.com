---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — Ashif Khan">
  <div class="nf-wrap">
    <p class="nf-code">404</p>
    <h1 class="nf-title">This page doesn't <em>exist</em></h1>
    <p class="nf-sub">Even the best targeting misses sometimes. Let's get you back on track.</p>
    <a href="/" class="nf-btn">← Back home</a>
  </div>

  <style>
    .nf-wrap {
      min-height: 88vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 4rem 2rem;
      position: relative;
    }

    .nf-code {
      font-family: var(--serif);
      font-size: clamp(6rem, 18vw, 11rem);
      line-height: 1;
      background: var(--grad);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      opacity: 0.9;
      margin-bottom: 1rem;
      animation: nfFloat 5s ease-in-out infinite;
    }

    @keyframes nfFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    .nf-title {
      font-family: var(--serif);
      font-weight: 400;
      font-size: clamp(1.5rem, 3.5vw, 2.25rem);
      color: var(--text);
      margin-bottom: 0.75rem;
    }

    .nf-title em {
      font-style: italic;
      background: var(--grad);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .nf-sub { color: var(--muted); font-weight: 300; margin-bottom: 2.25rem; }

    .nf-btn {
      display: inline-block;
      background: var(--grad);
      color: #0a0a0d;
      font-size: 0.9rem;
      font-weight: 600;
      padding: 0.85rem 1.6rem;
      border-radius: 100px;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 24px rgba(255, 106, 43, 0.3);
    }

    .nf-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 36px rgba(255, 106, 43, 0.45); }
  </style>
</BaseLayout>
