      font-size: 0.8rem;
      color: var(--accent);
      display: block;
      margin-bottom: 1.25rem;
    }

    .pillar-title {
      font-family: var(--serif);
      font-weight: 500;
      font-size: 1.35rem;
      letter-spacing: -0.01em;
      margin-bottom: 0.85rem;
      line-height: 1.25;
    }

    .pillar-body {
      font-size: 0.9rem;
      color: var(--muted);
      line-height: 1.75;
      font-weight: 300;
    }

    /* ── EXPERIENCE ── */
    .exp-section { background: var(--bg); }

    .exp-header { margin-bottom: 3rem; }

    .timeline {
      position: relative;
      padding-left: 1.5rem;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 0; top: 8px; bottom: 8px;
      width: 1px;
      background: linear-gradient(to bottom, var(--accent), rgba(255, 106, 43, 0.05));
    }

    .timeline-item {
      position: relative;
      padding: 0 0 2rem 2rem;
    }

    .timeline-item:last-child { padding-bottom: 0; }

    .timeline-dot {
      position: absolute;
      left: -0.62rem;
      top: 26px;
      width: 11px;
      height: 11px;
      border-radius: 50%;
      background: var(--bg);
      border: 2px solid var(--line-med);
      z-index: 1;
    }

    .timeline-item--current .timeline-dot {
      background: var(--accent);
      border-color: rgba(255, 106, 43, 0.4);
      box-shadow: 0 0 14px rgba(255, 106, 43, 0.7);
    }

    .timeline-card { padding: 1.75rem 2rem; }

    .timeline-item--current .timeline-card {
      border-color: rgba(255, 106, 43, 0.3);
      background: linear-gradient(160deg, rgba(255, 106, 43, 0.05), var(--surface) 45%);
    }

    .timeline-meta {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      margin-bottom: 0.6rem;
    }

    .timeline-period {
      font-family: var(--mono);
      font-size: 0.75rem;
      color: var(--faint);
    }

    .timeline-badge {
      font-family: var(--mono);
      font-size: 0.62rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #34d399;
      border: 1px solid rgba(52, 211, 153, 0.35);
      background: rgba(52, 211, 153, 0.07);
      padding: 0.15rem 0.6rem;
      border-radius: 100px;
    }

    .timeline-location {
      font-size: 0.78rem;
      color: var(--faint);
    }

    .timeline-company {
      font-family: var(--mono);
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent-2);
      margin-bottom: 0.25rem;
    }

    .timeline-role {
      font-size: 1.15rem;
      font-weight: 500;
      color: var(--text);
      margin-bottom: 0.5rem;
      line-height: 1.3;
    }

    .timeline-summary {
      font-size: 0.9rem;
      color: var(--muted);
      font-style: italic;
      font-family: var(--serif);
      margin-bottom: 1rem;
      line-height: 1.6;
    }

    .timeline-highlights {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
    }

    .timeline-highlights li {
      font-size: 0.875rem;
      color: var(--muted);
      line-height: 1.65;
      padding-left: 1.1rem;
      position: relative;
      font-weight: 300;
    }

    .timeline-highlights li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.6em;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--accent);
      opacity: 0.65;
    }

    .exp-earlier {
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid var(--line);
    }

    .exp-earlier-label {
      font-family: var(--mono);
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--faint);
      margin-bottom: 1.25rem;
    }

    .exp-earlier-list { display: flex; flex-direction: column; gap: 0.875rem; }

    .exp-earlier-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.875rem;
    }

    .exp-earlier-co { font-weight: 500; color: var(--text); }
    .exp-earlier-role { color: var(--muted); font-weight: 300; }
    .exp-earlier-year {
      margin-left: auto;
      font-family: var(--mono);
      font-size: 0.75rem;
      color: var(--faint);
    }

    /* ── BUILDING ── */
    .building-section { background: var(--bg-2); border-top: 1px solid var(--line); }

    .building-sub {
      color: var(--muted);
      font-weight: 300;
      max-width: 52ch;
      margin-bottom: 3rem;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }

    .project-card { padding: 2rem; }

    .project-card-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.1rem;
    }

    .project-icon { font-size: 1.5rem; }

    .project-title {
      font-family: var(--serif);
      font-weight: 500;
      font-size: 1.2rem;
      color: var(--text);
      margin-bottom: 0.625rem;
      line-height: 1.3;
    }

    .project-title-link { color: inherit; text-decoration: none; transition: color 0.2s; }
    .project-title-link:hover { color: var(--accent-2); }

    .project-desc {
      font-size: 0.875rem;
      color: var(--muted);
      line-height: 1.7;
      font-weight: 300;
    }

    .project-tag {
      font-family: var(--mono);
      font-size: 0.62rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent-2);
      border: 1px solid rgba(255, 106, 43, 0.3);
      padding: 0.25rem 0.65rem;
      border-radius: 100px;
    }

    .project-tag--live {
      color: #34d399;
      border-color: rgba(52, 211, 153, 0.35);
    }

    .project-link {
      display: inline-block;
      margin-top: 1.1rem;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--accent-2);
      text-decoration: none;
      transition: opacity 0.15s;
    }

    .project-link:hover { opacity: 0.75; }

    .project-card--cta {
      background: linear-gradient(150deg, rgba(255, 106, 43, 0.12), rgba(124, 92, 255, 0.08));
      border: 1px solid rgba(255, 106, 43, 0.25);
      border-radius: 16px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      gap: 1.5rem;
      padding: 2rem;
    }

    .project-cta-text {
      font-family: var(--serif);
      font-size: 1.5rem;
      color: var(--text);
      line-height: 1.35;
      letter-spacing: -0.01em;
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: none; }
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .hero-stats { gap: 1.25rem; }
      .stat-divider { display: none; }
      .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .pillars-grid { grid-template-columns: 1fr; }
      .projects-grid { grid-template-columns: 1fr; }
      .exp-earlier-item { flex-wrap: wrap; }
      .exp-earlier-year { margin-left: 0; }
      .timeline { padding-left: 1rem; }
      .timeline-item { padding-left: 1.25rem; }
      .timeline-card { padding: 1.4rem 1.25rem; }
    }
  </style>

  <script>
    // Typewriter rotation in hero
    const phrases = [
      'RAG help agent → GA at Yahoo DSP',
      'agentic campaign troubleshooting',
      'anomaly detection before impact',
      'contextual targeting: $600K → $1M/mo',
      'LLM guardrails adopted org-wide',
    ];
    const target = document.getElementById('typeTarget');
    let pi = 0, ci = 0, deleting = false;
    const tick = () => {
      if (!target) return;
      const phrase = phrases[pi];
      if (!deleting) {
        ci++;
        target.textContent = phrase.slice(0, ci);
        if (ci === phrase.length) { deleting = true; setTimeout(tick, 2200); return; }
        setTimeout(tick, 45 + Math.random() * 40);
      } else {
        ci--;
        target.textContent = phrase.slice(0, ci);
        if (ci === 0) { deleting = false; pi = (pi + 1) % phrases.length; setTimeout(tick, 350); return; }
        setTimeout(tick, 22);
      }
    };
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced && target) { target.textContent = phrases[0]; }
    else { setTimeout(tick, 1100); }

    // Mouse-follow glow on cards
    document.querySelectorAll<HTMLElement>('.glow-card').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const r = card.getBoundingClientRect();
        card.style.setProperty('--mx', `${e.clientX - r.left}px`);
        card.style.setProperty('--my', `${e.clientY - r.top}px`);
      });
    });

    // Subtle parallax on hero orbs
    if (!reduced) {
      const orbs = document.querySelectorAll<HTMLElement>('.orb');
      window.addEventListener('scroll', () => {
        const y = window.scrollY;
        if (y > window.innerHeight) return;
        orbs.forEach((orb, i) => {
          orb.style.translate = `0 ${y * (0.08 + i * 0.05)}px`;
        });
      }, { passive: true });
    }
  </script>
</BaseLayout>
