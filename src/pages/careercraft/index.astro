---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UploadZone from '../../components/careercraft/UploadZone.tsx';
---

<BaseLayout
  title="CareerCraft — AI Resume Rewriter"
  description="CareerCraft interviews you like a senior hiring manager would, then rewrites your resume with real metrics and stronger framing."
>
  <section class="cc-upload-section">
    <div class="cc-upload-inner">
      <div class="cc-header">
        <p class="cc-label">CareerCraft</p>
        <h1 class="cc-title">
          Your resume, rewritten<br />from the inside out
        </h1>
        <p class="cc-sub">
          Most resume tools polish your language. CareerCraft interviews you first —
          extracting the real metrics and achievements — then writes it properly.
        </p>
      </div>

      <UploadZone client:load />
    </div>
  </section>
</BaseLayout>

<style>
  /* Global spinner animation — used by all careercraft React components */
  :global(@keyframes cc-spin) {
    to { transform: rotate(360deg); }
  }
  :global(@keyframes cc-bounce) {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
    40% { transform: translateY(-4px); opacity: 1; }
  }

  .cc-upload-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: calc(var(--nav-h) + 3rem) 2rem 4rem;
    background: var(--paper);
  }

  .cc-upload-inner {
    max-width: 560px;
    margin: 0 auto;
    width: 100%;
  }

  .cc-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .cc-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .cc-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .cc-sub {
    font-size: 1rem;
    color: var(--ink-light);
    font-weight: 300;
    line-height: 1.7;
    max-width: 44ch;
    margin: 0 auto;
  }
</style>
