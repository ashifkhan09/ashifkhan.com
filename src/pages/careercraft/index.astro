---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UploadZone from '../../components/careercraft/UploadZone.tsx';
---

<BaseLayout
  title="CareerCraft — AI Resume Rewriter"
  description="CareerCraft interviews you like a senior hiring manager would, then rewrites your resume with real metrics and stronger framing."
>
  <section class="cc-upload-section cc-dark">
    <div class="cc-upload-inner">
      <div class="cc-header">
        <p class="cc-label">// CareerCraft</p>
        <h1 class="cc-title">
          Your resume, rewritten<br />from the <em>inside out</em>
        </h1>
        <p class="cc-sub">
          Most resume tools polish your language. CareerCraft interviews you first —
          extracting the real metrics and achievements — then writes it properly.
        </p>
      </div>

      <UploadZone client:load />
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* Dark remap of legacy vars for all CareerCraft React components */
  .cc-dark {
    --paper: #0e0f16;
    --paper-warm: #151721;
    --ink: #f2f1ec;
    --ink-light: rgba(242, 241, 236, 0.65);
    --ink-faint: rgba(242, 241, 236, 0.42);
    --border: rgba(242, 241, 236, 0.12);
    --border-med: rgba(242, 241, 236, 0.22);
    --accent-faint: rgba(255, 106, 43, 0.14);
  }

  @keyframes cc-spin {
    to { transform: rotate(360deg); }
  }
  @keyframes cc-bounce {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
    40% { transform: translateY(-4px); opacity: 1; }
  }
</style>

<style>
  .cc-upload-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: calc(var(--nav-h) + 3rem) 2rem 4rem;
    background: var(--bg);
    position: relative;
    overflow: hidden;
  }

  .cc-upload-section::before {
    content: '';
    position: absolute;
    left: 50%; top: -10%;
    width: 640px; height: 420px;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, rgba(255, 106, 43, 0.09), transparent 65%);
    pointer-events: none;
  }

  .cc-upload-inner {
    max-width: 560px;
    margin: 0 auto;
    width: 100%;
    position: relative;
  }

  .cc-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .cc-label {
    font-family: var(--mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .cc-title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .cc-title em {
    font-style: italic;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .cc-sub {
    font-size: 1rem;
    color: var(--muted);
    font-weight: 300;
    line-height: 1.7;
    max-width: 44ch;
    margin: 0 auto;
  }
</style>
