      background: rgba(250,249,247,0.025);
      border-bottom: 1px solid rgba(250,249,247,0.05);
    }

    /* Sections */
    .mkt-section {
      padding: 3rem 2rem;
      background: var(--ink);
    }

    .mkt-section--alt {
      background: #111110;
    }

    .mkt-inner {
      max-width: var(--max-w);
      margin: 0 auto;
    }

