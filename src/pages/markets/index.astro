---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Markets Dashboard — Ashif Khan"
  description="Real-time financial markets dashboard: crude oil, gold, silver, crypto, forex, US & India equities, bonds, treasury, futures, and live news."
>
  <div class="markets-page">

    <!-- ── PAGE HEADER ── -->
    <div class="mkt-header">
      <div class="mkt-header-inner">
        <div>
          <p class="mkt-label">Live Data</p>
          <h1 class="mkt-title">Markets Dashboard</h1>
          <p class="mkt-sub">Commodities · Crypto · Forex · Equities · Bonds · Futures · News</p>
        </div>
        <div class="mkt-clock-block">
          <span class="mkt-clock" id="mkt-clock"></span>
          <span class="mkt-status" id="mkt-status"></span>
        </div>
      </div>
    </div>

    <!-- ── TICKER TAPE ── -->
    <div class="ticker-band">
      <div class="tradingview-widget-container">
        <div class="tradingview-widget-container__widget"></div>
        <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-ticker-tape.js" async>
        {
          "symbols": [
            {"proName":"FOREXCOM:SPXUSD","title":"S&P 500"},
            {"proName":"FOREXCOM:NSXUSD","title":"NASDAQ 100"},
            {"proName":"FOREXCOM:DJI","title":"Dow Jones"},
            {"description":"VIX","proName":"CBOE:VIX"},
            {"description":"WTI Crude","proName":"TVC:USOIL"},
            {"description":"Gold","proName":"FX_IDC:XAUUSD"},
            {"description":"Silver","proName":"TVC:SILVER"},
            {"description":"Bitcoin","proName":"BITSTAMP:BTCUSD"},
            {"description":"Ethereum","proName":"BITSTAMP:ETHUSD"},
            {"description":"USD/INR","proName":"FX_IDC:USDINR"},
            {"description":"USD/CNY","proName":"FX_IDC:USDCNY"},
            {"description":"EUR/USD","proName":"FX:EURUSD"},
            {"description":"NIFTY 50","proName":"CAPITALCOM:IN50"},
            {"description":"US 10Y","proName":"FRED:DGS10"},
            {"description":"DXY","proName":"CAPITALCOM:DXY"},
            {"description":"S&P Futures","proName":"CAPITALCOM:US500"}
          ],
          "showSymbolLogo": true,
          "isTransparent": true,
          "displayMode": "adaptive",
          "colorTheme": "dark",
          "locale": "en"
        }
        </script>
      </div>
    </div>

    <!-- ── MARKET OVERVIEW ── -->
    <section class="mkt-section">
      <div class="mkt-inner">
        <h2 class="mkt-section-title">Market Overview</h2>
        <div class="overview-card">
          <div class="tradingview-widget-container" style="height:450px">
            <div class="tradingview-widget-container__widget" style="height:calc(100% - 32px)"></div>
            <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-market-overview.js" async>
            {
              "colorTheme": "dark",
              "dateRange": "12M",
              "showChart": true,
              "locale": "en",
              "isTransparent": true,
              "showSymbolLogo": true,
              "showFloatingTooltip": false,
              "width": "100%",
              "height": "450",
              "tabs": [
                {
                  "title": "Indices",
                  "symbols": [
                    {"s":"FOREXCOM:SPXUSD","d":"S&P 500"},
                    {"s":"FOREXCOM:NSXUSD","d":"NASDAQ 100"},
                    {"s":"FOREXCOM:DJI","d":"Dow Jones"},
                    {"s":"CBOE:VIX","d":"VIX Volatility"},
                    {"s":"CAPITALCOM:IN50","d":"NIFTY 50"},
                    {"s":"BSE:SENSEX","d":"BSE SENSEX"}
                  ],
                  "originalTitle": "Indices"
                },
                {
                  "title": "Commodities",
                  "symbols": [
                    {"s":"TVC:USOIL","d":"WTI Crude Oil"},
                    {"s":"FX_IDC:XAUUSD","d":"Gold"},
                    {"s":"TVC:SILVER","d":"Silver"},
                    {"s":"TVC:UKOIL","d":"Brent Crude"},
                    {"s":"TVC:PLATINUM","d":"Platinum"},
                    {"s":"TVC:PALLADIUM","d":"Palladium"}
                  ],
                  "originalTitle": "Commodities"
                },
                {
                  "title": "Crypto",
                  "symbols": [
                    {"s":"BITSTAMP:BTCUSD","d":"Bitcoin"},
                    {"s":"BITSTAMP:ETHUSD","d":"Ethereum"},
                    {"s":"BINANCE:SOLUSDT","d":"Solana"},
                    {"s":"BINANCE:BNBUSDT","d":"BNB"}
                  ],
                  "originalTitle": "Crypto"
                },
                {
                  "title": "Bonds",
                  "symbols": [
                    {"s":"AMEX:TLT","d":"US 20Y+ Bond ETF"},
                    {"s":"AMEX:IEF","d":"US 7-10Y Bond ETF"},
                    {"s":"AMEX:SHY","d":"US 1-3Y Bond ETF"},
                    {"s":"AMEX:EMB","d":"EM Bond ETF"}
                  ],
                  "originalTitle": "Bonds"
                }
              ]
            }
            </script>
          </div>
        </div>
      </div>
    </section>

    <!-- ── COMMODITIES ── -->
    <section class="mkt-section mkt-section--alt">
      <div class="mkt-inner">
        <h2 class="mkt-section-title">Commodities</h2>
        <div class="chart-grid chart-grid--4">

          <div class="chart-card">
            <p class="chart-label">WTI Crude Oil</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"TVC:USOIL","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true,"largeChartUrl":""}
              </script>
            </div>
          </div>

          <div class="chart-card">
            <p class="chart-label">Gold (XAU/USD)</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"FX_IDC:XAUUSD","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true,"largeChartUrl":""}
              </script>
            </div>
          </div>

          <div class="chart-card">
            <p class="chart-label">Silver (XAG/USD)</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"TVC:SILVER","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true,"largeChartUrl":""}
              </script>
            </div>
          </div>

          <div class="chart-card">
            <p class="chart-label">Natural Gas</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"MCX:NATURALGAS1!","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true,"largeChartUrl":""}
              </script>
            </div>
          </div>

          <div class="chart-card">
            <p class="chart-label">Brent Crude Oil</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"TVC:UKOIL","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true,"largeChartUrl":""}
              </script>
            </div>
          </div>

          <div class="chart-card">
            <p class="chart-label">Platinum</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"TVC:PLATINUM","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true,"largeChartUrl":""}
              </script>
            </div>
          </div>

          <div class="chart-card">
            <p class="chart-label">Copper</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"MCX:COPPER1!","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true,"largeChartUrl":""}
              </script>
            </div>
          </div>

          <div class="chart-card">
            <p class="chart-label">Palladium</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"TVC:PALLADIUM","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true,"largeChartUrl":""}
              </script>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── CRYPTO ── -->
    <section class="mkt-section">
      <div class="mkt-inner">
        <h2 class="mkt-section-title">Crypto</h2>
        <div class="chart-card crypto-full-card">
          <div class="tradingview-widget-container">
            <div class="tradingview-widget-container__widget"></div>
            <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-symbol-overview.js" async>
            {
              "symbols": [
                ["Bitcoin","BITSTAMP:BTCUSD|1D"],
                ["Ethereum","BITSTAMP:ETHUSD|1D"],
                ["Solana","BINANCE:SOLUSDT|1D"],
                ["BNB","BINANCE:BNBUSDT|1D"]
              ],
              "chartOnly": false,
              "width": "100%",
              "height": "480",
              "locale": "en",
              "colorTheme": "dark",
              "autosize": true,
              "showVolume": true,
              "showMA": false,
              "hideDateRanges": false,
              "hideMarketStatus": false,
              "hideSymbolLogo": false,
              "scalePosition": "right",
              "scaleMode": "Normal",
              "fontFamily": "DM Sans, system-ui, sans-serif",
              "fontSize": "10",
              "noTimeScale": false,
              "valuesTracking": "1",
              "changeMode": "price-and-percent",
              "chartType": "area",
              "lineWidth": 2,
              "lineType": 0,
              "dateRanges": ["1d|1","1m|30","3m|60","12m|1D","all|1M"]
            }
            </script>
          </div>
        </div>
      </div>
    </section>

    <!-- ── FOREIGN EXCHANGE ── -->
    <section class="mkt-section mkt-section--alt">
      <div class="mkt-inner">
        <h2 class="mkt-section-title">Foreign Exchange</h2>
        <div class="chart-grid chart-grid--4">

          <div class="chart-card">
            <p class="chart-label">USD / INR</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"FX_IDC:USDINR","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
              </script>
            </div>
          </div>

          <div class="chart-card">
            <p class="chart-label">USD / CNY</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"FX_IDC:USDCNY","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
              </script>
            </div>
          </div>

          <div class="chart-card">
            <p class="chart-label">EUR / USD</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"FX:EURUSD","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
              </script>
            </div>
          </div>

          <div class="chart-card">
            <p class="chart-label">USD / JPY</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"FX:USDJPY","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
              </script>
            </div>
          </div>

          <div class="chart-card">
            <p class="chart-label">GBP / USD</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"FX:GBPUSD","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
              </script>
            </div>
          </div>

          <div class="chart-card">
            <p class="chart-label">USD / AUD</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"FX:AUDUSD","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
              </script>
            </div>
          </div>

          <div class="chart-card">
            <p class="chart-label">USD / CAD</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"FX:USDCAD","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
              </script>
            </div>
          </div>

          <div class="chart-card">
            <p class="chart-label">US Dollar Index (DXY)</p>
            <div class="tradingview-widget-container">
              <div class="tradingview-widget-container__widget"></div>
              <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
              {"symbol":"CAPITALCOM:DXY","width":"100%","height":"220","locale":"en","dateRange":"6M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
              </script>
            </div>
          </div>

        </div>

        <!-- Forex Cross Rates Matrix -->
        <div class="cross-rates-wrap">
          <p class="cross-rates-label">Cross Rates Matrix</p>
          <div class="tradingview-widget-container" style="height:420px">
            <div class="tradingview-widget-container__widget" style="height:calc(100% - 32px)"></div>
            <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-forex-cross-rates.js" async>
            {
              "width": "100%",
              "height": "420",
              "currencies": ["EUR","USD","JPY","GBP","INR","CNY","AUD","CAD"],
              "isTransparent": true,
              "colorTheme": "dark",
              "locale": "en",
              "backgroundColor": "#0e0e0d"
            }
            </script>
          </div>
        </div>

      </div>
    </section>

    <!-- ── US EQUITY MARKETS ── -->
    <section class="mkt-section">
      <div class="mkt-inner">
        <h2 class="mkt-section-title">Equity Markets</h2>

        <div class="equities-group">
          <p class="equities-flag-label">🇺🇸 United States</p>
          <div class="chart-grid chart-grid--4">

            <div class="chart-card">
              <p class="chart-label">S&P 500</p>
              <div class="tradingview-widget-container">
                <div class="tradingview-widget-container__widget"></div>
                <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
                {"symbol":"FOREXCOM:SPXUSD","width":"100%","height":"220","locale":"en","dateRange":"12M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
                </script>
              </div>
            </div>

            <div class="chart-card">
              <p class="chart-label">NASDAQ 100</p>
              <div class="tradingview-widget-container">
                <div class="tradingview-widget-container__widget"></div>
                <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
                {"symbol":"FOREXCOM:NSXUSD","width":"100%","height":"220","locale":"en","dateRange":"12M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
                </script>
              </div>
            </div>

            <div class="chart-card">
              <p class="chart-label">Dow Jones 30</p>
              <div class="tradingview-widget-container">
                <div class="tradingview-widget-container__widget"></div>
                <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
                {"symbol":"FOREXCOM:DJI","width":"100%","height":"220","locale":"en","dateRange":"12M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
                </script>
              </div>
            </div>

            <div class="chart-card">
              <p class="chart-label">Russell 2000</p>
              <div class="tradingview-widget-container">
                <div class="tradingview-widget-container__widget"></div>
                <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
                {"symbol":"AMEX:IWM","width":"100%","height":"220","locale":"en","dateRange":"12M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
                </script>
              </div>
            </div>

          </div>
        </div>

        <div class="equities-group">
          <p class="equities-flag-label">🇮🇳 India</p>
          <div class="chart-grid chart-grid--4">

            <div class="chart-card">
              <p class="chart-label">NIFTY 50</p>
              <div class="tradingview-widget-container">
                <div class="tradingview-widget-container__widget"></div>
                <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
                {"symbol":"NSEIX:NIFTY1!","width":"100%","height":"220","locale":"en","dateRange":"12M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
                </script>
              </div>
            </div>

            <div class="chart-card">
              <p class="chart-label">BSE SENSEX</p>
              <div class="tradingview-widget-container">
                <div class="tradingview-widget-container__widget"></div>
                <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
                {"symbol":"BSE:SENSEX","width":"100%","height":"220","locale":"en","dateRange":"12M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
                </script>
              </div>
            </div>

            <div class="chart-card">
              <p class="chart-label">NIFTY Bank</p>
              <div class="tradingview-widget-container">
                <div class="tradingview-widget-container__widget"></div>
                <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
                {"symbol":"NSE:BANKNIFTY","width":"100%","height":"220","locale":"en","dateRange":"12M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
                </script>
              </div>
            </div>

            <div class="chart-card">
              <p class="chart-label">NIFTY IT</p>
              <div class="tradingview-widget-container">
                <div class="tradingview-widget-container__widget"></div>
                <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-mini-symbol-overview.js" async>
                {"symbol":"NSE:IT","width":"100%","height":"220","locale":"en","dateRange":"12M","colorTheme":"dark","trendLineColor":"rgba(200,80,26,1)","underLineColor":"rgba(200,80,26,0.1)","isTransparent":true,"autosize":true}
                </script>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ── BONDS & TREASURY ── -->
    <section class="mkt-section mkt-section--alt">
      <div class="mkt-inner">
        <h2 class="mkt-section-title">Bonds & Treasury Yields</h2>
        <div class="chart-grid chart-grid--4">

          <div class="chart-card">
            <p class="chart-label">US 2Y Treasury</p>
            <div class="tradingview-widget-container">
