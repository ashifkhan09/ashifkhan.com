  <script is:inline>
    // Live clock + market status
    function updateClock() {
      const now = new Date();
      const clockEl = document.getElementById('mkt-clock');
      const statusEl = document.getElementById('mkt-status');
      if (!clockEl || !statusEl) return;

      clockEl.textContent = now.toLocaleString('en-US', {
        weekday: 'short', month: 'short', day: 'numeric',
        hour: '2-digit', minute: '2-digit', second: '2-digit',
        timeZoneName: 'short'
      });

      // NYSE hours: Mon–Fri 9:30–16:00 ET
      const nyStr = now.toLocaleString('en-US', { timeZone: 'America/New_York' });
      const ny = new Date(nyStr);
      const d = ny.getDay(), h = ny.getHours(), m = ny.getMinutes();
      const isWeekday = d >= 1 && d <= 5;
      const afterOpen = h > 9 || (h === 9 && m >= 30);
      const beforeClose = h < 16;
      const nyseOpen = isWeekday && afterOpen && beforeClose;

      // NSE hours: Mon–Fri 9:15–15:30 IST
      const istStr = now.toLocaleString('en-US', { timeZone: 'Asia/Kolkata' });
      const ist = new Date(istStr);
      const di = ist.getDay(), hi = ist.getHours(), mi = ist.getMinutes();
      const istWeekday = di >= 1 && di <= 5;
      const nseOpen = istWeekday && ((hi > 9 || (hi === 9 && mi >= 15)) && (hi < 15 || (hi === 15 && mi <= 30)));

      let statusText = '';
      if (nyseOpen && nseOpen) statusText = '🟢 NYSE + NSE OPEN';
      else if (nyseOpen) statusText = '🟢 NYSE OPEN';
      else if (nseOpen) statusText = '🟡 NSE OPEN';
      else statusText = '🔴 MARKETS CLOSED';

      statusEl.textContent = statusText;
      statusEl.style.color = (nyseOpen || nseOpen) ? 'rgba(34,197,94,0.85)' : 'rgba(250,249,247,0.25)';
    }

    updateClock();
    setInterval(updateClock, 1000);

    // ── EARNINGS CALENDAR ────────────────────────────────────────────────
    (function() {
      const wrap    = document.getElementById('earnings-wrap');
      const daysEl  = document.getElementById('earn-days');
      const weekLbl = document.getElementById('earn-week-label');
      const prevBtn = document.getElementById('earn-prev');
      const nextBtn = document.getElementById('earn-next');
      if (!wrap) return;

      let weekOffset = 0;
      let dayIdx = 0;
      let dates = [];

      function iso(d) { return d.toISOString().split('T')[0]; }
      function fmtShort(d) { return d.toLocaleDateString('en-US',{month:'short',day:'numeric'}); }
      function fmtDay(d)   { return d.toLocaleDateString('en-US',{weekday:'short'}); }

      function weekDates(offset) {
        const now = new Date();
        const dow = now.getDay(); // 0=Sun
        const mon = new Date(now);
        mon.setDate(now.getDate() - (dow === 0 ? 6 : dow - 1) + offset * 7);
        return Array.from({length:5}, (_, i) => { const d=new Date(mon); d.setDate(mon.getDate()+i); return d; });
      }

      function renderTabs() {
        daysEl.innerHTML = dates.map((d,i) => `
          <button class="earn-day-btn ${i===dayIdx?'active':''}" data-i="${i}">
            <span class="earn-day-name">${fmtDay(d)}</span>
            <span class="earn-day-date">${fmtShort(d)}</span>
          </button>`).join('');
        daysEl.querySelectorAll('.earn-day-btn').forEach(b =>
          b.addEventListener('click', () => { dayIdx=+b.dataset.i; renderTabs(); loadDay(); }));
      }

      function renderTable(rows) {
        if (!rows || !rows.length)
          return `<div class="earn-state">No earnings scheduled for this day.</div>`;
        const shown = rows.slice(0, 80);
        return `<div class="earn-scroll"><table class="earn-tbl">
          <thead><tr>
            <th>Ticker</th><th>Company</th><th>Time</th>
            <th>EPS Est.</th><th>Last YR EPS</th><th>Mkt Cap</th><th>Quarter</th>
          </tr></thead>
          <tbody>${shown.map(r => {
            const t = r.time||'';
            const cls = t.includes('Before')?'bmo':t.includes('After')?'amc':'';
            const tLbl = t.includes('Before')?'🌅 BMO':t.includes('After')?'🌙 AMC': t||'—';
            const mc = r.marketCap && r.marketCap!=='—' ? r.marketCap : '';
            return `<tr>
              <td class="earn-td-ticker">${r.symbol||'—'}</td>
              <td class="earn-td-name">${r.name||'—'}</td>
              <td class="earn-td-time ${cls}">${tLbl}</td>
              <td class="earn-td-num">${r.epsForecast||'—'}</td>
              <td class="earn-td-num">${r.lastYearEPS||'—'}</td>
              <td class="earn-td-mktcap">${mc}</td>
              <td class="earn-td-num">${r.fiscalQuarterEnding||'—'}</td>
            </tr>`;
          }).join('')}</tbody>
        </table>${rows.length>80?`<p class="earn-more">+${rows.length-80} more — showing top 80</p>`:''}</div>`;
      }

      async function loadDay() {
        wrap.innerHTML = `<div class="earn-state">⏳ Loading…</div>`;
        const date = iso(dates[dayIdx]);
        const nasdaqUrl = `https://api.nasdaq.com/api/calendar/earnings?date=${date}`;
        // Try multiple CORS proxies in sequence for reliability
        const proxies = [
          `https://corsproxy.io/?${encodeURIComponent(nasdaqUrl)}`,
          `https://api.allorigins.win/raw?url=${encodeURIComponent(nasdaqUrl)}`,
          `https://api.codetabs.com/v1/proxy?quest=${encodeURIComponent(nasdaqUrl)}`
        ];
        let rows = null;
        for (const url of proxies) {
          try {
            const res = await fetch(url, { headers: {'Accept':'application/json'}, signal: AbortSignal.timeout(8000) });
            if (!res.ok) continue;
            const json = await res.json();
            rows = json?.data?.rows ?? json?.data?.earnings?.rows ?? [];
            if (rows !== null) break;
          } catch(e) { continue; }
        }
        if (rows !== null) {
          wrap.innerHTML = renderTable(rows);
          return;
        }
        wrap.innerHTML = `<div class="earn-state">
          Could not load earnings data.&nbsp;
          <a href="https://www.nasdaq.com/market-activity/earnings" target="_blank" rel="noopener">
            View on Nasdaq →
          </a>
        </div>`;
      }

      function loadWeek() {
        dates = weekDates(weekOffset);
        const todayStr = iso(new Date());
        const ti = dates.findIndex(d => iso(d) === todayStr);
        dayIdx = ti >= 0 ? ti : (weekOffset === 0 ? 0 : 0);
        weekLbl.textContent =
          weekOffset === 0 ? 'This Week' :
          weekOffset === 1 ? 'Next Week' :
          weekOffset === -1 ? 'Last Week' :
          `${fmtShort(dates[0])} – ${fmtShort(dates[4])}`;
        renderTabs();
        loadDay();
      }

      prevBtn.addEventListener('click', () => { weekOffset--; loadWeek(); });
      nextBtn.addEventListener('click', () => { weekOffset++; loadWeek(); });
      loadWeek();
    })();
  </script>
</BaseLayout>
