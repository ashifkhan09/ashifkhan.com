      font-size: 0.875rem;
      color: rgba(250,249,247,0.45);
      font-variant-numeric: tabular-nums;
      margin-bottom: 0.375rem;
    }

    .mkt-status {
      display: block;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    /* Ticker Band */
