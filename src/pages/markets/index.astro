    }

    /* Footer note */
    .mkt-footer-note {
      padding: 1.5rem 2rem;
      background: #0a0a09;
      border-top: 1px solid rgba(250,249,247,0.05);
    }

    .mkt-footer-note p {
      font-size: 0.75rem;
      color: rgba(250,249,247,0.2);
